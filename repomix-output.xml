<file path="app.js">
const express = require('express');
const app = express();

app.use(express.json());

// In-memory storage for citas (appointments)
let citas = [];
let nextId = 1;

// GET /citas - List all appointments
app.get('/citas', (req, res) => {
  res.json(citas);
});

// GET /citas/:id - Get a single appointment
app.get('/citas/:id', (req, res) => {
  const cita = citas.find(c => c.id === parseInt(req.params.id));
  if (!cita) {
    return res.status(404).json({ error: 'Cita no encontrada' });
  }
  res.json(cita);
});

// POST /citas - Create a new appointment
app.post('/citas', (req, res) => {
  const { titulo, fecha, hora, descripcion } = req.body;

  if (!titulo || !fecha || !hora) {
    return res.status(400).json({ error: 'Titulo, fecha y hora son requeridos' });
  }

  const nuevaCita = {
    id: nextId++,
    titulo,
    fecha,
    hora,
    descripcion: descripcion || '',
    createdAt: new Date().toISOString()
  };

  citas.push(nuevaCita);
  res.status(201).json(nuevaCita);
});

// PUT /citas/:id - Update an appointment
app.put('/citas/:id', (req, res) => {
  const index = citas.findIndex(c => c.id === parseInt(req.params.id));
  if (index === -1) {
    return res.status(404).json({ error: 'Cita no encontrada' });
  }

  const { titulo, fecha, hora, descripcion } = req.body;

  if (!titulo || !fecha || !hora) {
    return res.status(400).json({ error: 'Titulo, fecha y hora son requeridos' });
  }

  citas[index] = {
    ...citas[index],
    titulo,
    fecha,
    hora,
    descripcion: descripcion || citas[index].descripcion
  };

  res.json(citas[index]);
});

// DELETE /citas/:id - Delete an appointment
app.delete('/citas/:id', (req, res) => {
  const index = citas.findIndex(c => c.id === parseInt(req.params.id));
  if (index === -1) {
    return res.status(404).json({ error: 'Cita no encontrada' });
  }

  const deleted = citas.splice(index, 1)[0];
  res.json({ message: 'Cita eliminada', cita: deleted });
});

// Helper to reset state (used in tests)
app._resetCitas = () => {
  citas = [];
  nextId = 1;
};

module.exports = app;
